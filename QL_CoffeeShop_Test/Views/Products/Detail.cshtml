@model QL_CoffeeShop_Test.Models.Product
@{
    ViewData["Title"] = Model.Name;
    Layout = "_Layout";
}

<div class="container my-5 py-5" style="min-height: 70vh;">
    <div class="card-wrapper">
        <div class="row align-items-center justify-content-center">
            <div class="col-12 col-lg-6 mb-4 mb-lg-0">
                <div class="image-wrapper">
                    <img src="@Model.ImageUrl" alt="@Model.Name"
                         style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px;" class="shadow-sm">
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="text-box" style="padding: 20px;">
                    <h1 class="mbr-title mbr-fonts-style display-2">
                        <strong>@Model.Name</strong>
                    </h1>
                    <p class="mbr-text mbr-fonts-style mt-3 display-7 text-muted" style="line-height: 1.6;">
                        @Model.detail
                    </p>
                    <div class="cost my-4">
                        <span class="currentcost mbr-fonts-style pr-2 display-2" style="color: #232323; font-weight: 300;">
                            @Model.Price.ToString("C", new System.Globalization.CultureInfo("en-US"))
                        </span>
                    </div>
                    <div class="mbr-section-btn pt-3">
                        <a asp-controller="Cart" asp-action="AddToShoppingCart" asp-route-id="@Model.Id"
                               class="btn btn-primary display-4">
                            <span class="mbrib-cart-add mbr-iconfont mbr-iconfont-btn"></span>Add to cart&nbsp;
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>